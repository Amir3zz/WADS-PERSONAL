generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  firebaseUid   String   @unique
  email         String   @unique
  name          String?
  image         String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  todos         Todo[]
  boards        Board[]
  studySessions StudySession[]

  accounts      Account[]
  sessions      Session[]

  @@index([email])
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completed])
}

model Board {
  id          String   @id @default(cuid())
  title       String
  description String?
  icon        String?
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  columns Column[]
  labels  Label[]

  @@index([userId])
}

model Column {
  id        String   @id @default(cuid())
  title     String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board   Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]

  @@index([boardId, position])
}

model Card {
  id          String   @id @default(cuid())
  title       String
  description String?

  position  Int
  completed Boolean @default(false)

  dueDate      DateTime?
  priority     String?
  aiSubtasks   String?
  aiSuggestion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  columnId String
  column   Column @relation(fields: [columnId], references: [id], onDelete: Cascade)

  labels CardLabel[]

  @@index([columnId, position])
  @@index([dueDate])
}

model Label {
  id      String @id @default(cuid())
  name    String
  color   String

  boardId String
  board   Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards CardLabel[]

  @@unique([boardId, name])
  @@index([boardId])
}

model CardLabel {
  id String @id @default(cuid())

  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
}

model StudySession {
  id              String   @id @default(cuid())
  title           String
  subject         String?
  notes           String?

  startedAt       DateTime
  endedAt         DateTime?
  durationMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

model Account {
  id                    String   @id
  userId                String
  accountId             String
  providerId            String

  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope    String?
  idToken  String?
  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}